{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "revisum",
  "version": "0.3.0",
  "identifier": "com.vinicius.revisum",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Revisum",
        "maximized": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/revisum.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "pt-BR", "fr-FR"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:revisum.db"
      ]
    }
  }
}
