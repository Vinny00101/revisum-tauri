{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "store:default",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/images/user/avatar/*" }]
    }
  ]
}